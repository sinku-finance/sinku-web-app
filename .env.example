NEXT_PUBLIC_API_URL=http://localhost:8082
NEXT_PUBLIC_BASE_URL=https://sinku.finance

# Waitlist storage — Neon Postgres (server-side only, never NEXT_PUBLIC)
DATABASE_URL=postgres://user:pass@host.neon.tech/dbname?sslmode=require

# Resend — matches backend env names (server-side only)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@sinku.finance
RESEND_FROM_NAME=Sinku

# Per-IP request rate limiting (recommended for the public write endpoints).
# Without these the limiter no-ops; the waitlist still has a DB row-cap, but
# the referral endpoint relies on this — provision an Upstash Redis / Vercel KV.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
